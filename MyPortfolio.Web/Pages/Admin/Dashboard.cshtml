@page
@model MyPortfolio.Web.Pages.Admin.DashboardModel
@using System.Text.Json
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid px-4 py-5">
    <h2 class="glitch-text mb-5" data-text="ANALYTICS CENTER">ANALYTICS CENTER</h2>

    @* STAT CARDS *@
    <div class="row g-4 mb-5">
        <div class="col-md-6 col-xl-3">
            <div class="glass-panel p-4 d-flex align-items-center justify-content-between h-100 border-start border-4 border-primary">
                <div>
                    <h3 class="text-white fw-bold display-5 mb-0">@Model.TotalSongs</h3>
                    <p class="text-white-50 small text-uppercase fw-bold mb-0">Total Projects</p>
                </div>
                <div class="text-primary display-5"><i class="fas fa-music"></i></div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="glass-panel p-4 d-flex align-items-center justify-content-between h-100 border-start border-4 border-warning">
                <div>
                    <h3 class="text-white fw-bold display-5 mb-0">@Model.TotalPlays</h3>
                    <p class="text-white-50 small text-uppercase fw-bold mb-0">Total Plays</p>
                </div>
                <div class="text-warning display-5"><i class="fas fa-headphones"></i></div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="glass-panel p-4 d-flex align-items-center justify-content-between h-100 border-start border-4 border-success">
                <div>
                    <h3 class="text-white fw-bold display-5 mb-0">@Model.TotalDownloads</h3>
                    <p class="text-white-50 small text-uppercase fw-bold mb-0">CV Downloads</p>
                </div>
                <div class="text-success display-5"><i class="fas fa-file-download"></i></div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="glass-panel p-4 d-flex align-items-center justify-content-between h-100 border-start border-4 border-info">
                <div>
                    <h3 class="text-white fw-bold display-5 mb-0">@Model.TotalQrScans</h3>
                    <p class="text-white-50 small text-uppercase fw-bold mb-0">QR Scans</p>
                </div>
                <div class="text-info display-5"><i class="fas fa-qrcode"></i></div>
            </div>
        </div>
    </div>

    @* TOP TRENDING *@
    <div class="glass-panel p-4 mb-5">
        <h4 class="text-white fw-bold mb-4 border-bottom border-secondary pb-2">
            <i class="fas fa-fire text-warning me-2"></i>Top Trending Projects
        </h4>

        <div class="row g-4 align-items-center">
            @* CỘT TRÁI: DANH SÁCH (Đã được nới rộng và căn trái) *@
            <div class="col-lg-6 order-2 order-lg-1">
                <div class="d-flex flex-column gap-3">
                    @for (int i = 0; i < Model.SongTitles.Length; i++)
                    {
                        var rank = i + 1;
                        var title = Model.SongTitles[i];
                        var playCount = Model.PlayCounts[i];
                        var maxPlay = Model.PlayCounts.Length > 0 ? Model.PlayCounts[0] : 1;
                        var barWidth = maxPlay > 0 ? (int)((double)playCount / maxPlay * 100) : 0;

                        var rankColor = rank switch
                        {
                            1 => "text-warning",   // Vàng
                            2 => "text-white-50",  // Bạc
                            3 => "text-danger",    // Đồng
                            _ => "text-white-50"
                        };
                        var rankIcon = rank switch
                        {
                            1 => "fas fa-crown",
                            2 => "fas fa-medal",
                            3 => "fas fa-award",
                            _ => "fas fa-hashtag"
                        };

                        <div class="d-flex align-items-center gap-3 p-3 rounded"
                             style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06);">
                            <div class="@rankColor text-center" style="width: 32px; flex-shrink: 0; font-size: 1.2rem;">
                                @if (rank <= 3)
                                {
                                    <i class="@rankIcon"></i>
                                }
                                else
                                {
                                    <span class="fw-bold">@rank</span>
                                }
                            </div>
                            <div class="flex-grow-1 overflow-hidden">
                                <div class="text-white fw-bold text-truncate fs-6" title="@title">@title</div>
                                <div class="mt-2" style="height: 6px; background: rgba(255,255,255,0.1); border-radius: 3px;">
                                    <div style="width: @(barWidth)%; height: 100%; background: @(rank == 1 ? "#f9c23c" : rank == 2 ? "#b3b3b3" : rank == 3 ? "#cd7f32" : "#1db954"); border-radius: 3px; transition: width 1s ease;"></div>
                                </div>
                            </div>
                            <div class="text-end" style="flex-shrink: 0; min-width: 70px;">
                                <span class="@rankColor fw-bold fs-5">@playCount.ToString("N0")</span>
                                <div class="text-white-50" style="font-size: 0.75rem;">plays</div>
                            </div>
                        </div>
                    }

                    @if (Model.SongTitles.Length == 0)
                    {
                        <div class="text-white-50 text-center fst-italic py-4">Chưa có dữ liệu.</div>
                    }
                </div>
            </div>

            @* CỘT PHẢI: BIỂU ĐỒ *@
            <div class="col-lg-6 order-1 order-lg-2">
                <div style="height: 350px; position: relative;">
                    <canvas id="playsChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    @* TRAFFIC + RECENT VISITORS *@
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="glass-panel p-4 h-100">
                <h4 class="text-white fw-bold mb-4 border-bottom border-secondary pb-2">
                    <i class="fas fa-wave-square text-info me-2"></i>Profile Traffic (7 Days)
                </h4>
                <div style="height: 300px; position: relative;">
                    <canvas id="trafficChart"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="glass-panel p-4 h-100">
                <h4 class="text-white fw-bold mb-4 border-bottom border-secondary pb-2">
                    <i class="fas fa-user-secret text-danger me-2"></i>Recent Visitors
                </h4>
                <div class="d-flex flex-column gap-3">
                    @foreach (var log in Model.RecentLogs)
                    {
                        <div class="p-2 rounded bg-dark border-start border-3 @(log.Action.Contains("Download") ? "border-success" : "border-info")">
                            <div class="d-flex justify-content-between">
                                <span class="text-white fw-bold small">@log.Action</span>
                                <span class="text-white-50 small" style="font-size: 0.75rem;">
                                    @log.Time.ToLocalTime().ToString("dd/MM HH:mm")
                                </span>
                            </div>
                            <div class="text-secondary small mt-1">
                                IP: <span class="text-warning visitor-ip">@log.IPAddress</span>
                                <span class="geo-location text-info fst-italic"> (Đang tra cứu...)</span>
                            </div>
                        </div>
                    }
                    @if (!Model.RecentLogs.Any())
                    {
                        <div class="text-white-50 text-center fst-italic py-4">Chưa có hoạt động nào.</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"
        integrity="sha512-CQBWl4fJDsMeQEiQ9c6dL4yo9K6d0aPMMwwKaW7U91LPqLfe6VPL62bH7Mq75V70h56Jc15pB6d5o+a2s9J/4A=="
        crossorigin="anonymous"
        referrerpolicy="no-referrer"></script>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        // =========================================
        // 1. BIỂU ĐỒ CỘT (TOP TRENDING)
        // =========================================
        const titles = @Html.Raw(Model.SongTitles != null ? JsonSerializer.Serialize(Model.SongTitles) : "[]");
        const counts = @Html.Raw(Model.PlayCounts != null ? JsonSerializer.Serialize(Model.PlayCounts) : "[]");

        const ctxPlays = document.getElementById('playsChart').getContext('2d');
        const gradientPlays = ctxPlays.createLinearGradient(0, 0, 0, 400);
        gradientPlays.addColorStop(0, 'rgba(249, 194, 60, 0.9)');
        gradientPlays.addColorStop(0.5, 'rgba(188, 19, 254, 0.7)');
        gradientPlays.addColorStop(1, 'rgba(29, 185, 84, 0.2)');

        new Chart(ctxPlays, {
            type: 'bar',
            data: {
                labels: titles,
                datasets: [{
                    label: 'Lượt nghe',
                    data: counts,
                    backgroundColor: gradientPlays,
                    borderColor: '#f9c23c',
                    borderWidth: 1,
                    borderRadius: 6,
                    barPercentage: 0.6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: ctx => ` ${ctx.parsed.y.toLocaleString()} lượt nghe`
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { color: 'rgba(255,255,255,0.05)' },
                        ticks: { color: '#b3b3b3', callback: v => v.toLocaleString() }
                    },
                    x: {
                        grid: { display: false },
                        ticks: { color: '#fff', font: { size: 10 }, maxRotation: 45 }
                    }
                }
            }
        });

        // =========================================
        // 2. BIỂU ĐỒ ĐƯỜNG (TRAFFIC 7 NGÀY)
        // =========================================
        const trafficLabels = @Html.Raw(string.IsNullOrEmpty(Model.ChartLabelsJson) ? "[]" : Model.ChartLabelsJson);
        const downloadData  = @Html.Raw(string.IsNullOrEmpty(Model.DownloadDataJson) ? "[]" : Model.DownloadDataJson);
        const scanData      = @Html.Raw(string.IsNullOrEmpty(Model.ScanDataJson) ? "[]" : Model.ScanDataJson);

        const ctxTraffic = document.getElementById('trafficChart').getContext('2d');

        new Chart(ctxTraffic, {
            type: 'line',
            data: {
                labels: trafficLabels,
                datasets: [
                    {
                        label: 'CV Downloads',
                        data: downloadData,
                        borderColor: '#1db954',
                        backgroundColor: 'rgba(29, 185, 84, 0.1)',
                        borderWidth: 3, tension: 0.4, fill: true,
                        pointBackgroundColor: '#1db954'
                    },
                    {
                        label: 'QR Scans',
                        data: scanData,
                        borderColor: '#00d4ff',
                        backgroundColor: 'rgba(0, 212, 255, 0.1)',
                        borderWidth: 3, tension: 0.4, fill: true,
                        pointBackgroundColor: '#00d4ff'
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { labels: { color: '#fff' } } },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { color: '#b3b3b3', stepSize: 1 },
                        grid: { color: 'rgba(255,255,255,0.05)' }
                    },
                    x: {
                        ticks: { color: '#b3b3b3' },
                        grid: { color: 'rgba(255,255,255,0.05)' }
                    }
                }
            }
        });

        // =========================================
        // 3. IP GEOLOCATION (Có Cache chống Rate Limit)
        // =========================================
        async function fetchGeoData() {
            const ipElements = document.querySelectorAll('.visitor-ip');
            const ipCache = {};

            for (let el of ipElements) {
                const ip      = el.innerText.trim();
                const geoSpan = el.nextElementSibling;

                if (ip === '::1' || ip === '127.0.0.1') {
                    geoSpan.innerText = " (Localhost)";
                    continue;
                }

                if (ipCache[ip]) {
                    geoSpan.innerText = ipCache[ip];
                    continue;
                }

                try {
                    const res  = await fetch(`https://ipwho.is/${ip}`);
                    const data = await res.json();

                    const locationText = data.success
                        ? ` (${data.city}, ${data.country_code} — ${data.connection?.isp ?? ''})`
                        : " (Không xác định)";

                    geoSpan.innerText = locationText;
                    ipCache[ip] = locationText;
                } catch {
                    geoSpan.innerText = " (Lỗi tra cứu)";
                }
            }
        }

        fetchGeoData();
    });
</script>