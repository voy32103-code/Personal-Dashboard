@page
@{
    ViewData["Title"] = "Contact Me";
}

<div class="container-fluid p-0 d-flex align-items-center justify-content-center" style="min-height: 80vh;">
    <div class="glass-panel p-5 m-4 border-0 w-100" style="max-width: 600px; background: rgba(18, 18, 18, 0.6); box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);">
        
        <h2 class="glitch-text display-5 fw-bold mb-4 text-center" data-text="Get In Touch">Get In Touch</h2>
        <p class="text-white-50 text-center mb-4">Bạn có dự án thú vị cần hợp tác? Hãy gửi lời nhắn ngay dưới đây nhé!</p>

        <!-- Hộp thông báo phản hồi chung -->
        <div id="response-alert" class="alert d-none mb-4" role="alert"></div>

        <form id="contact-form" novalidate>
            @Html.AntiForgeryToken()

            <div class="mb-4">
                <label class="form-label text-white-50 fw-bold mb-2">Họ và Tên</label>
                <input type="text" id="input-name" class="neumorph-input" placeholder="Nguyễn Văn A" required>
                <div class="invalid-feedback text-danger mt-2 small" id="error-name" style="display: none;"></div>
            </div>

            <div class="mb-4">
                <label class="form-label text-white-50 fw-bold mb-2">Địa chỉ Email</label>
                <input type="email" id="input-email" class="neumorph-input" placeholder="name@example.com" required>
                <div class="invalid-feedback text-danger mt-2 small" id="error-email" style="display: none;"></div>
            </div>

            <div class="mb-4">
                <label class="form-label text-white-50 fw-bold mb-2">Lời nhắn</label>
                <textarea id="input-message" class="neumorph-input" rows="5" placeholder="Chia sẻ ý tưởng hoặc nội dung dự án của bạn..." required></textarea>
                <div class="invalid-feedback text-danger mt-2 small" id="error-message" style="display: none;"></div>
            </div>

            <button type="submit" id="btn-submit" class="neumorph-btn w-100 py-3 rounded-pill text-success mt-2">
                <span id="btn-text"><i class="fas fa-paper-plane me-2"></i>Gửi Tin Nhắn</span>
                <span id="btn-spinner" class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            const $form = $('#contact-form');
            const $btnSubmit = $('#btn-submit');
            const $btnText = $('#btn-text');
            const $btnSpinner = $('#btn-spinner');
            const $alert = $('#response-alert');

            // Lấy Antiforgery Token tự động từ thẻ sinh bởi Razor
            const token = $('input[name="__RequestVerificationToken"]').val();

            $form.on('submit', function (e) {
                e.preventDefault();

                // Ẩn tất cả các lỗi cũ
                $('.invalid-feedback').hide().text('');
                $alert.addClass('d-none').removeClass('alert-success alert-danger');

                // Thu thập dữ liệu form
                const payload = {
                    name: $('#input-name').val().trim(),
                    email: $('#input-email').val().trim(),
                    message: $('#input-message').val().trim()
                };

                // Hiển thị trạng thái Loading
                $btnSubmit.prop('disabled', true);
                $btnText.addClass('d-none');
                $btnSpinner.removeClass('d-none');

                $.ajax({
                    url: '/api/SystemMetrics/contact',
                    type: 'POST',
                    contentType: 'application/json; charset=utf-8',
                    headers: {
                        'RequestVerificationToken': token
                    },
                    data: JSON.stringify(payload),
                    success: function (response) {
                        // Hiển thị thông báo thành công
                        $alert.removeClass('d-none')
                              .addClass('alert-success')
                              .text(response.message || 'Gửi tin nhắn thành công! Yên sẽ phản hồi bạn sớm.');
                        
                        // Reset form
                        $form[0].reset();
                    },
                    error: function (xhr) {
                        $alert.removeClass('d-none').addClass('alert-danger');

                        if (xhr.status === 400 && xhr.responseJSON && xhr.responseJSON.errors) {
                            $alert.text('Thông tin nhập vào chưa hợp lệ. Vui lòng kiểm tra lại các trường.');
                            
                            // Hiển thị chi tiết lỗi dưới mỗi input tương ứng
                            const errors = xhr.responseJSON.errors;
                            
                            if (errors.Name) {
                                $('#error-name').text(errors.Name[0]).show();
                            }
                            if (errors.Email) {
                                $('#error-email').text(errors.Email[0]).show();
                            }
                            if (errors.Message) {
                                $('#error-message').text(errors.Message[0]).show();
                            }
                        } else {
                            $alert.text('Đã xảy ra lỗi hệ thống khi gửi lời nhắn. Vui lòng thử lại sau.');
                        }
                    },
                    complete: function () {
                        // Tắt trạng thái Loading
                        $btnSubmit.prop('disabled', false);
                        $btnSpinner.addClass('d-none');
                        $btnText.removeClass('d-none');
                    }
                });
            });
        });
    </script>
}