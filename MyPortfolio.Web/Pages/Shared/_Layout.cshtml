<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - My Portfolio</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="manifest" href="~/manifest.json">

    <script src="https://cdnjs.cloudflare.com/ajax/libs/Sortable/1.14.0/Sortable.min.js"
            integrity="sha512-zYXldzJsDrNKVxZUNNhwqoqm4JUJjL3PRWYCCclm2XkECx+aVbFuiQUI1Z88uU47D4Q328UNZr1hiachSXz86w=="
            crossorigin="anonymous"
            referrerpolicy="no-referrer"></script>
    <meta name="theme-color" content="#1db954">
</head>
<body>
    <div class="aurora-bg-container">
        <div class="aurora-blob blob-1"></div>
        <div class="aurora-blob blob-2"></div>
        <div class="aurora-blob blob-3"></div>
    </div>

    <div class="spotify-layout">
        <div class="sidebar">
            <a href="/" class="d-flex align-items-center gap-2 mb-4 text-decoration-none text-white fs-4 fw-bold ps-2">
                <i class="fab fa-spotify text-success fa-lg"></i>
                <span class="glitch-text" data-text="PORTFOLIO" style="font-size: 1.5rem;">PORTFOLIO</span>
            </a>

            <div class="nav-links">
                <a href="/" class="nav-btn @(ViewContext.RouteData.Values["page"]?.ToString() == "/Index" && Context.Request.Query["Mode"] != "library" ? "active" : "")">
                    <i class="fas fa-home"></i> Home
                </a>
                <a href="/Profile" class="nav-btn @(ViewContext.RouteData.Values["page"]?.ToString() == "/Profile" ? "active" : "")">
                    <i class="fas fa-user-astronaut"></i> Tech Profile
                </a>
                <a href="/Portfolio/Details/4" class="nav-btn">
                    <i class="fas fa-file-code"></i> Live CV
                </a>

                <div class="mt-4 mb-2 px-3 text-uppercase text-white-50 small fw-bold" style="letter-spacing: 1px;">Library</div>

                <a href="/?Mode=library" class="nav-btn @(Context.Request.Query["Mode"] == "library" ? "active" : "")">
                    <i class="fas fa-heart text-danger"></i> Liked Songs
                </a>

                @if (User.Identity.IsAuthenticated)
                {
                    <a href="/Admin/Dashboard" class="neumorph-btn btn-sm rounded-pill text-decoration-none py-2 mb-2 w-100 text-warning">
                        <i class="fas fa-chart-line me-2"></i> Dashboard
                    </a>
                    <div class="mt-4 p-3 glass-panel text-center">
                        <div class="small text-white-50 mb-2">Admin Panel</div>
                        <a href="/Portfolio/Create" class="neumorph-btn btn-sm rounded-pill text-decoration-none py-2 mb-2 w-100">
                            <i class="fas fa-plus me-2"></i> New Project
                        </a>
                        <a href="/Login?handler=Logout" class="text-danger small text-decoration-none hover-underline">Logout</a>
                    </div>
                }
                else
                {
                    <a href="/Login" class="nav-btn mt-auto">
                        <i class="fas fa-sign-in-alt"></i> Login
                    </a>
                }
            </div>
        </div>

        <div class="main-view">
            @RenderBody()
        </div>

        <div class="player-bar">
            <div class="d-flex align-items-center gap-3" style="width: 30%;">
                <img id="current-img" src="https://cdn-icons-png.flaticon.com/512/174/174872.png" style="width: 50px; height: 50px; border-radius: 8px; display: none; object-fit: cover; box-shadow: 0 0 10px rgba(0,0,0,0.5);" />
                <div id="song-info" style="display: none;">
                    <div id="current-title" class="text-white fw-bold small">Chọn bài hát...</div>
                    <div id="current-desc" class="text-white-50 small" style="font-size: 0.7rem;">...</div>
                </div>
            </div>

            <div class="d-flex flex-column align-items-center justify-content-center" style="width: 40%;">
                <div class="d-flex align-items-center gap-3 mb-2">
                    <button class="btn-control" id="shuffle-btn" onclick="toggleShuffle()" title="Shuffle"><i class="fas fa-random"></i></button>
                    <button class="btn-control" onclick="prevSong()" title="Previous"><i class="fas fa-step-backward"></i></button>
                    <button class="btn-play-round" onclick="togglePlay()" title="Play/Pause (Space)"><i class="fas fa-play" id="play-icon"></i></button>
                    <button class="btn-control" onclick="nextSong()" title="Next"><i class="fas fa-step-forward"></i></button>
                    <button class="btn-control" id="repeat-btn" onclick="toggleRepeat()" title="Repeat"><i class="fas fa-redo"></i></button>
                </div>
                <div class="d-flex align-items-center gap-2 w-100">
                    <span id="current-time" class="small text-white-50">0:00</span>
                    <div class="progress-bar-wrapper flex-grow-1" style="height: 4px; background: #444; border-radius: 2px; cursor: pointer;">
                        <div id="progress-bar" style="width: 0%; height: 100%; background: #1db954; border-radius: 2px; transition: width 0.1s linear;"></div>
                    </div>
                    <span id="duration-time" class="small text-white-50">0:00</span>
                </div>
            </div>

            <div class="d-flex justify-content-end align-items-center" style="width: 30%;">
                <button class="btn-control me-2" onclick="toggleMute()" title="Mute (M)"><i class="fas fa-volume-up" id="volume-icon"></i></button>
                <input type="range" id="volume-slider" min="0" max="1" step="0.01" class="form-range" style="width: 80px;">
            </div>
        </div>
    </div>

    <audio id="audio-player"></audio>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"
            integrity="sha512-lz/XU4/f4X9hVpYqV2z+k9t+2M4/30T6yfpwO/vj6D7mdPJKOQ8TGD8/joVjR48c+vJqD+0/J5XN+o4iT/wX3A=="
            crossorigin="anonymous"
            referrerpolicy="no-referrer"></script>

    <script>
        // --- 1. KHỞI TẠO BIẾN ---
        var audio = document.getElementById("audio-player");
        var playIcon = document.getElementById("play-icon");
        var progressBar = document.getElementById("progress-bar");
        var currentTimeLabel = document.getElementById("current-time");
        var durationTimeLabel = document.getElementById("duration-time");
        var repeatBtn = document.getElementById("repeat-btn");
        var shuffleBtn = document.getElementById("shuffle-btn");
        var volumeSlider = document.getElementById("volume-slider");
        var volumeIcon = document.getElementById("volume-icon");

        // Load settings from localStorage
        var isRepeat = localStorage.getItem("repeatMode") === "true";
        var isShuffle = localStorage.getItem("shuffleMode") === "true";
        var playlist = [];
        var currentIndex = -1;
        var lastVolume = 1;
        var playTimeout = null; 

        // Constant cho Prev song
        const PREV_THRESHOLD_SECONDS = 3;

        window.addEventListener("load", function() {
            if (isRepeat) repeatBtn.style.color = "#1db954";
            if (isShuffle) shuffleBtn.style.color = "#1db954";
        });

        // ==========================================
        //  SIGNALR SETUP ( Reconnection)
        // ==========================================
        var connection = new signalR.HubConnectionBuilder()
            .withUrl("/musicHub")
            .withAutomaticReconnect() // SignalR native reconnect
            .build();

        connection.onclose(async () => {
            console.warn("❌ Connection lost, retrying...");
            setTimeout(() => startConnection(), 5000);
        });

        async function startConnection() {
            try {
                await connection.start();
                console.log("✅ Đã kết nối vào phòng nhạc!");
            } catch (err) {
                console.error(err);
                setTimeout(() => startConnection(), 5000);
            }
        }

        connection.on("ReceiveMusicAction", function (action, url, time) {
            if (action === "play") {
                if (audio.src !== url) audio.src = url;
                if (Math.abs(audio.currentTime - time) > 1) audio.currentTime = time;

                var playPromise = audio.play();
                if (playPromise !== undefined) {
                    playPromise.then(() => updatePlayIcon(true))
                               .catch(error => console.log("Tự động phát bị chặn: " + error));
                }
            } else if (action === "pause") {
                audio.pause();
                updatePlayIcon(false);
            }
        });

        startConnection();

        // ==========================================
        // LOGIC PHÁT NHẠC
        // ==========================================
        function playMusic(url, title, img, desc, artist, listData) {
            // Debounce chống click đúp (Race Condition)
            if (playTimeout) return;
            playTimeout = setTimeout(() => { playTimeout = null; }, 500);

            //  Defensive Mapping
            if (listData && Array.isArray(listData)) {
                playlist = listData
                    .filter(item => item.audioUrl || item.AudioUrl)
                    .map(item => ({
                        audioUrl: item.audioUrl || item.AudioUrl || "",
                        title: item.title || item.Title || "Unknown",
                        imageUrl: item.imageUrl || item.ImageUrl || "https://via.placeholder.com/50",
                        artist: item.artist || item.Artist || "Unknown",
                        id: parseInt(item.id || item.Id || 0)
                    }));
            } else if (playlist.length === 0) {
                playlist = [{ audioUrl: url, title: title, imageUrl: img, artist: artist, id: 0 }];
            }

            var foundIndex = playlist.findIndex(p => p.audioUrl === url);
            if (foundIndex !== -1) {
                currentIndex = foundIndex;
            } else {
                playlist.unshift({ audioUrl: url, title: title, imageUrl: img, artist: artist, id: 0 });
                currentIndex = 0;
            }

            loadSong(playlist[currentIndex]);

            if (connection.state === signalR.HubConnectionState.Connected) {
                connection.invoke("SendMusicAction", "play", url, 0).catch(err => console.error(err));
            }
        }

        function loadSong(song) {
            if (!song || !song.audioUrl) return;

            document.getElementById("current-title").innerText = song.title;
            document.getElementById("current-desc").innerText = song.artist || "Unknown";
            document.getElementById("current-img").src = song.imageUrl;
            document.getElementById("current-img").style.display = "block";
            document.getElementById("song-info").style.display = "block";

            if (audio.src !== song.audioUrl) {
                audio.src = song.audioUrl;

                // Xử lý Promise khi Play
                var playPromise = audio.play();
                if (playPromise !== undefined) {
                    playPromise.then(() => {
                        updatePlayIcon(true);
                    }).catch(error => {
                        console.error("❌ Play failed: " + error);
                        alert("Trình duyệt chặn tự động phát. Vui lòng bấm Play.");
                    });
                }

                // Fetch an toàn có Timeout
                if (song.id > 0) {
                    fetch(`/?handler=CountPlay&id=${song.id}`, {
                        method: 'GET',
                        signal: AbortSignal.timeout(5000)
                    }).catch(err => console.warn("Lỗi đếm lượt nghe: " + err));
                }
            } else if (audio.paused) {
                audio.play();
                updatePlayIcon(true);
            }
        }

        // ==========================================
        //  NÚT ĐIỀU KHIỂN & SỰ KIỆN
        // ==========================================
        function togglePlay() {
            if (!audio.src) return;
            if (audio.paused) {
                audio.play();
                updatePlayIcon(true);
                if (connection.state === signalR.HubConnectionState.Connected) {
                    connection.invoke("SendMusicAction", "play", audio.src, audio.currentTime);
                }
            } else {
                audio.pause();
                updatePlayIcon(false);
                if (connection.state === signalR.HubConnectionState.Connected) {
                    connection.invoke("SendMusicAction", "pause", audio.src, audio.currentTime);
                }
            }
        }

        function updatePlayIcon(isPlaying) {
            if (isPlaying) {
                playIcon.classList.replace("fa-play", "fa-pause");
            } else {
                playIcon.classList.replace("fa-pause", "fa-play");
            }
        }

        // Sửa thuật toán Shuffle tránh infinite loop
        function getNextShuffleIndex() {
            if (playlist.length <= 1) return 0;
            let newIndex;
            let attempts = 0;
            do {
                newIndex = Math.floor(Math.random() * playlist.length);
                attempts++;
            } while (newIndex === currentIndex && attempts < 10);
            return newIndex;
        }

        function nextSong() {
            if (playlist.length === 0) return;
            if (isShuffle) {
                currentIndex = getNextShuffleIndex();
            } else {
                currentIndex = (currentIndex + 1) % playlist.length;
            }
            loadSong(playlist[currentIndex]);

            if (connection.state === signalR.HubConnectionState.Connected) {
                connection.invoke("SendMusicAction", "play", playlist[currentIndex].audioUrl, 0);
            }
        }

        function prevSong() {
            if (playlist.length === 0) return;
            // Xóa số Magic
            if (audio.currentTime > PREV_THRESHOLD_SECONDS) {
                audio.currentTime = 0;
                audio.play().catch(e => console.error(e));
                return;
            }
            if (isShuffle) {
                currentIndex = getNextShuffleIndex();
            } else {
                currentIndex = (currentIndex - 1 + playlist.length) % playlist.length;
            }
            loadSong(playlist[currentIndex]);

            if (connection.state === signalR.HubConnectionState.Connected) {
                connection.invoke("SendMusicAction", "play", playlist[currentIndex].audioUrl, 0);
            }
        }

        function toggleShuffle() {
            isShuffle = !isShuffle;
            localStorage.setItem("shuffleMode", isShuffle); 
            shuffleBtn.style.color = isShuffle ? "#1db954" : "#b3b3b3";
        }

        function toggleRepeat() {
            isRepeat = !isRepeat;
            localStorage.setItem("repeatMode", isRepeat); 
            repeatBtn.style.color = isRepeat ? "#1db954" : "#b3b3b3";
        }

        // --- BẮT LỖI & SỰ KIỆN AUDIO ---
        audio.addEventListener("error", function() {
            console.error("❌ Audio error: " + (audio.error ? audio.error.message : "Unknown"));
        });

        audio.addEventListener("timeupdate", function() {
            if (audio.duration) {
                var percent = (audio.currentTime / audio.duration) * 100;
                progressBar.style.width = percent + "%";
                currentTimeLabel.innerText = formatTime(audio.currentTime);
            }
        });

        audio.addEventListener("loadedmetadata", function() {
            durationTimeLabel.innerText = formatTime(audio.duration);
        });

        audio.addEventListener("ended", function() {
            if (isRepeat) {
                audio.currentTime = 0;
                // Handle play error in loop
                var playPromise = audio.play();
                if (playPromise) {
                    playPromise.catch(err => {
                        console.error("Failed to replay: " + err);
                        nextSong();
                    });
                }
            } else {
                nextSong();
            }
        });

        //  Xử lý click thanh Seekbar an toàn
        document.querySelector(".progress-bar-wrapper").addEventListener("click", function(e) {
            if (!audio.src || audio.networkState === HTMLMediaElement.NETWORK_NO_SOURCE) return;
            if (audio.duration) {
                var rect = this.getBoundingClientRect();
                var percent = (e.clientX - rect.left) / rect.width;
                percent = Math.max(0, Math.min(1, percent)); // Kẹp giới hạn 0-1

                var newTime = percent * audio.duration;
                audio.currentTime = newTime;

                if (connection.state === signalR.HubConnectionState.Connected) {
                    connection.invoke("SendMusicAction", "play", audio.src, newTime);
                }
            }
        });

        // ==========================================
        // VOLUME & UTILS
        // ==========================================
        // Ép kiểu dữ liệu (ParseFloat)
        function setVolume(val) {
            val = parseFloat(val);
            audio.volume = Math.max(0, Math.min(1, val));
            updateVolumeIcon(val);
        }

        function toggleMute() {
            if (audio.volume > 0) {
                lastVolume = audio.volume;
                setVolume(0);
                volumeSlider.value = 0;
            } else {
                setVolume(lastVolume);
                volumeSlider.value = lastVolume;
            }
        }

        function updateVolumeIcon(vol) {
            vol = parseFloat(vol);
            volumeIcon.className = '';
            if (vol === 0) volumeIcon.className = 'fas fa-volume-mute';
            else if (vol < 0.5) volumeIcon.className = 'fas fa-volume-down';
            else volumeIcon.className = 'fas fa-volume-up';
        }

        volumeSlider.oninput = function() { setVolume(this.value); };

        //  Hiển thị đúng định dạng giờ
        function formatTime(s) {
            if (isNaN(s) || s < 0) return "0:00";
            var hours = Math.floor(s / 3600);
            var minutes = Math.floor((s % 3600) / 60);
            var seconds = Math.floor(s % 60);
            var timeStr = minutes + ":" + (seconds < 10 ? "0" : "") + seconds;
            if (hours > 0) timeStr = hours + ":" + (minutes < 10 ? "0" : "") + timeStr;
            return timeStr;
        }

        setVolume(1);

        // ==========================================
        // ⌨️ UPGRADE 1: KEYBOARD SHORTCUTS 
        // ==========================================
        document.addEventListener("keydown", function(e) {
            // Bỏ qua nếu user đang gõ chữ vào thanh tìm kiếm hoặc form
            if (e.target.matches("input, textarea")) return;

            switch(e.code) {
                case "Space":
                    e.preventDefault(); // Tránh bị cuộn trang
                    togglePlay();
                    break;
                case "ArrowRight":
                    nextSong();
                    break;
                case "ArrowLeft":
                    prevSong();
                    break;
                case "KeyM":
                    toggleMute();
                    break;
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>